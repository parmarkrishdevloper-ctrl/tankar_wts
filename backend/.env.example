# ─── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ─── Database ──────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/tankar_whatsapp

# ─── Auth ──────────────────────────────────────────────────────
JWT_SECRET=replace_me_with_a_long_random_secret

# ─── WhatsApp Cloud API ────────────────────────────────────────
VERIFY_TOKEN=tankar_verify_token
WHATSAPP_TOKEN=your_long_lived_whatsapp_token
PHONE_NUMBER_ID=123456789012345
# App secret from Meta — used to verify webhook signatures
META_APP_SECRET=your_meta_app_secret

# ─── LLM ───────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxx

# ─── CORS ──────────────────────────────────────────────────────
# Comma-separated origins. Leave blank for permissive (dev only).
CORS_ORIGINS=http://localhost:5173,https://tankarsolutions.tech
